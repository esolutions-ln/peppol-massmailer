# PostgreSQL
POSTGRES_PASSWORD=your_secure_postgres_password

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your_smtp_username
SMTP_PASSWORD=your_smtp_password

# Email
MAIL_FROM=no-reply@esolutions.co.zw
MAIL_FROM_NAME=InvoiceDirect

# App
APP_BASE_URL=https://ap.invoicedirect.biz
RATE_LIMIT=10
BATCH_SIZE=50

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password

# Google OAuth
GOOGLE_OAUTH2_CREDENTIALS_PATH=/etc/mailer/google-oauth-credentials.json
GOOGLE_OAUTH2_REFRESH_TOKEN=your_google_refresh_token
