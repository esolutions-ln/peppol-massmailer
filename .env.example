# ── PostgreSQL (existing platform instance) ──
DB_HOST=your-postgres-hostname.platform.com
DB_PORT=5432
DB_USER=mailer
POSTGRES_PASSWORD=your_secure_postgres_password

# ── SMTP / Brevo ──
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USERNAME=your_brevo_smtp_username
SMTP_PASSWORD=your_brevo_smtp_password
SPRING_MAIL_USERNAME=your_brevo_smtp_username
SPRING_MAIL_PASSWORD=your_brevo_smtp_password
BREVO_ENABLED=true
BREVO_API_KEY=your_brevo_api_key

# ── Email ──
MAIL_FROM=no-reply@invoicedirect.biz
MAIL_FROM_NAME=InvoiceDirect Mailer

# ── App ──
APP_BASE_URL=https://ap.invoicedirect.biz
RATE_LIMIT=100
BATCH_SIZE=50
MAX_PDF_BYTES=10485760
HIBERNATE_DDL_AUTO=validate
SWAGGER_ENABLED=false

# ── Admin (required — bootstraps the default admin user) ──
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your_secure_admin_password

# ── Webhook signing (required — must be >=32 chars) ──
WEBHOOK_SECRET=your_webhook_signing_secret_min_32_chars

# ── Google OAuth (optional — only if massmailer.gmail-oauth2.enabled=true) ──
GOOGLE_OAUTH2_CREDENTIALS_PATH=
GOOGLE_OAUTH2_REFRESH_TOKEN=
