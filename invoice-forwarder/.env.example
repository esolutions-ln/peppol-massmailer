# Remote Mass Mailer (ap.invoicedirect.biz)
FORWARDER_MAILER_URL=https://ap.invoicedirect.biz
FORWARDER_MAILER_ADMIN_USER=ops@yourcompany.co.zw
FORWARDER_MAILER_ADMIN_PASS=replace-me

# The organization on the remote mailer that this site sends as.
# Every customer registered by the forwarder is created under this org.
FORWARDER_DEFAULT_ORG_ID=00000000-0000-0000-0000-000000000000

# Host path that the ERP writes invoice PDFs + sidecars into.
HOST_INBOX_DIR=/var/lib/invoicedirect/inbox

# Batch window — invoices collected in this rolling window go in one campaign.
FORWARDER_BATCH_WINDOW_SECONDS=30

# How often to ask the upstream for delivery status on in-flight campaigns.
FORWARDER_STATUS_POLL_SECONDS=60
