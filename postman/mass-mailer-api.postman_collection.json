			"item": [
				{
					"name": "Admin Login",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('adminToken', json.token);",
									"    console.log('Admin token saved');",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"admin\",\n  \"password\": \"your-admin-password\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/admin/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "admin", "login"]
						},
						"description": "Login as admin. The token is automatically saved to the `adminToken` variable."
					},
					"response": []
				},
				{
					"name": "Admin Logout",
