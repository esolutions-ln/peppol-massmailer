{
	"info": {
		"name": "eSolutions Mass Mailer API",
		"description": "Complete API collection for the eSolutions Fiscalised Invoice Mass Mailer.\n\n## Setup\n1. Set the `baseUrl` variable to your environment (default: http://localhost:8080)\n2. Register an organisation using the \"Register Organisation\" request\n3. Copy the `apiKey` from the response into the `apiKey` variable\n4. You're ready to send invoices!\n\n## Authentication\nMost endpoints require the `X-API-Key` header. This is automatically set from the `apiKey` collection variable.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:8080",
			"type": "string"
		},
		{
			"key": "apiKey",
			"value": "",
			"type": "string"
		},
		{
			"key": "adminToken",
			"value": "",
			"type": "string"
		},
		{
			"key": "orgId",
			"value": "",
			"type": "string"
		},
		{
			"key": "campaignId",
			"value": "",
			"type": "string"
		}
	],
	"auth": {
		"type": "apikey",
		"apikey": [
			{
				"key": "key",
				"value": "X-API-Key",
				"type": "string"
			},
			{
				"key": "value",
				"value": "{{apiKey}}",
				"type": "string"
			},
			{
				"key": "in",
				"value": "header",
				"type": "string"
			}
		]
	},
	"item": [
		{
			"name": "Getting Started",
			"description": "Start here. Register your organisation and send your first invoice.",
			"item": [
				{
					"name": "1. Register Organisation",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 201) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('apiKey', json.apiKey);",
									"    pm.collectionVariables.set('orgId', json.id);",
									"    console.log('API Key saved (show only once): ' + json.apiKey);",
									"    console.log('Org ID saved: ' + json.id);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "noauth"
						},
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"user\": {\n    \"firstName\": \"John\",\n    \"lastName\": \"Doe\",\n    \"jobTitle\": \"Finance Manager\",\n    \"emailAddress\": \"john@yourcompany.co.zw\"\n  },\n  \"name\": \"Your Company\",\n  \"slug\": \"your-company\",\n  \"senderEmail\": \"invoices@yourcompany.co.zw\",\n  \"senderDisplayName\": \"Your Company Invoices\",\n  \"accountsEmail\": \"accounts@yourcompany.co.zw\",\n  \"companyAddress\": \"123 Samora Machel Ave, Harare\",\n  \"vatNumber\": \"12345678\",\n  \"deliveryMode\": \"EMAIL\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/organizations",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "organizations"]
						},
						"description": "Register a new organisation. **Save the API key from the response -- it is shown only once.**\n\nRate limit: 10 per IP per hour."
					},
					"response": []
				},
				{
					"name": "2. Send Single Invoice (JSON)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"to\": \"customer@acmecorp.co.zw\",\n  \"recipientName\": \"Acme Corporation\",\n  \"subject\": \"Invoice INV-2026-0001 from Your Company\",\n  \"templateName\": \"invoice\",\n  \"invoiceNumber\": \"INV-2026-0001\",\n  \"invoiceDate\": \"2026-04-14\",\n  \"dueDate\": \"2026-05-14\",\n  \"totalAmount\": 1250.00,\n  \"vatAmount\": 187.50,\n  \"currency\": \"USD\",\n  \"fiscalDeviceSerialNumber\": \"FD-SN-12345\",\n  \"fiscalDayNumber\": \"42\",\n  \"globalInvoiceCounter\": \"0001234\",\n  \"verificationCode\": \"ABCD-EFGH-1234\",\n  \"qrCodeUrl\": \"https://fdms.zimra.co.zw/verify?code=ABCD-EFGH-1234\",\n  \"pdfBase64\": \"JVBERi0xLjQKMSAwIG9iago...\",\n  \"pdfFileName\": \"INV-2026-0001.pdf\",\n  \"variables\": {\n    \"companyName\": \"Your Company\",\n    \"accountsEmail\": \"accounts@yourcompany.co.zw\"\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/mail/invoice",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "mail", "invoice"]
						},
						"description": "Send a single invoice email synchronously. Returns the delivery result immediately.\n\nSupply either `pdfFilePath` OR `pdfBase64` (not both)."
					},
					"response": []
				},
				{
					"name": "3. Send Single Invoice (File Upload)",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "pdf",
									"type": "file",
									"src": "",
									"description": "The invoice PDF file"
								},
								{
									"key": "metadata",
									"value": "{\"to\":\"customer@acme.co.zw\",\"subject\":\"Your Invoice\",\"templateName\":\"invoice\",\"invoiceNumber\":\"INV-2026-0042\",\"totalAmount\":1250.00,\"currency\":\"USD\"}",
									"type": "text",
									"description": "Invoice metadata as JSON string"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/mail/invoice/upload",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "mail", "invoice", "upload"]
						},
						"description": "Send a single invoice with the PDF uploaded as a multipart file.\n\nMax file size: 20 MB."
					},
					"response": []
				}
			]
		},
		{
			"name": "Campaigns",
			"description": "Batch invoice dispatch -- create campaigns, monitor progress, retry failures.",
			"item": [
				{
					"name": "Create Campaign",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 202) {",
									"    var json = pm.response.json();",
									"    pm.collectionVariables.set('campaignId', json.campaignId);",
									"    console.log('Campaign ID saved: ' + json.campaignId);",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"March 2026 Invoices\",\n  \"subject\": \"Your Invoice from Your Company\",\n  \"templateName\": \"invoice\",\n  \"organizationId\": \"{{orgId}}\",\n  \"templateVariables\": {\n    \"companyName\": \"Your Company\",\n    \"accountsEmail\": \"accounts@yourcompany.co.zw\"\n  },\n  \"recipients\": [\n    {\n      \"email\": \"alice@acmecorp.co.zw\",\n      \"name\": \"Alice Moyo\",\n      \"invoiceNumber\": \"INV-2026-0100\",\n      \"invoiceDate\": \"2026-03-01\",\n      \"dueDate\": \"2026-03-31\",\n      \"totalAmount\": 2400.00,\n      \"vatAmount\": 360.00,\n      \"currency\": \"USD\",\n      \"fiscalDeviceSerialNumber\": \"FD-SN-12345\",\n      \"fiscalDayNumber\": \"60\",\n      \"globalInvoiceCounter\": \"10001\",\n      \"verificationCode\": \"AAAA-BBBB-1111\",\n      \"qrCodeUrl\": \"https://fdms.zimra.co.zw/verify?code=AAAA-BBBB-1111\",\n      \"pdfBase64\": \"JVBERi0xLjQK...\"\n    },\n    {\n      \"email\": \"bob@vendor.co.zw\",\n      \"name\": \"Bob Nyathi\",\n      \"invoiceNumber\": \"INV-2026-0101\",\n      \"invoiceDate\": \"2026-03-01\",\n      \"dueDate\": \"2026-03-31\",\n      \"totalAmount\": 850.00,\n      \"vatAmount\": 127.50,\n      \"currency\": \"USD\",\n      \"pdfBase64\": \"JVBERi0xLjQK...\"\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/campaigns",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "campaigns"]
						},
						"description": "Create and dispatch a batch invoice campaign. Returns 202 Accepted immediately.\n\nRecipients are processed asynchronously in batches of 50."
					},
					"response": []
				},
				{
					"name": "Get Campaign Status",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/campaigns/{{campaignId}}",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "campaigns", "{{campaignId}}"]
						},
						"description": "Poll this endpoint to track campaign progress.\n\nStatuses: CREATED, QUEUED, IN_PROGRESS, COMPLETED, PARTIALLY_FAILED, FAILED, CANCELLED"
					},
					"response": []
				},
				{
					"name": "List All Campaigns",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/campaigns",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "campaigns"]
						},
						"description": "List all campaigns ordered by creation date."
					},
					"response": []
				},
				{
					"name": "Retry Failed Recipients",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/campaigns/{{campaignId}}/retry",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "campaigns", "{{campaignId}}", "retry"]
						},
						"description": "Re-queue all FAILED recipients in a campaign for another delivery attempt."
					},
					"response": []
				}
			]
		},
		{
			"name": "ERP Integration",
			"description": "Fetch invoices from your ERP system and dispatch them.",
			"item": [
				{
					"name": "Dispatch from ERP",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 202) {",
									"    var json = pm.response.json();",
									"    if (json.emailCampaignId) {",
									"        pm.collectionVariables.set('campaignId', json.emailCampaignId);",
									"    }",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"campaignName\": \"Sage March 2026 Invoices\",\n  \"subject\": \"Your Invoice from eSolutions\",\n  \"templateName\": \"invoice\",\n  \"erpSource\": \"SAGE_INTACCT\",\n  \"tenantId\": \"ESOLUTIONS_ZW\",\n  \"organizationId\": \"{{orgId}}\",\n  \"invoiceIds\": [\"INV-2026-0100\", \"INV-2026-0101\"],\n  \"templateVariables\": {\n    \"companyName\": \"eSolutions\",\n    \"accountsEmail\": \"accounts@esolutions.co.zw\"\n  }\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/erp/dispatch",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "erp", "dispatch"]
						},
						"description": "Fetch invoices from your ERP and dispatch as a campaign.\n\nSupported ERP sources: SAGE_INTACCT, QUICKBOOKS_ONLINE, DYNAMICS_365, ODOO, GENERIC_API"
					},
					"response": []
				},
				{
					"name": "Upload Multiple PDFs and Dispatch",
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "metadata",
									"value": "{\"campaignName\":\"March 2026\",\"subject\":\"Your Invoice\",\"templateName\":\"invoice\",\"organizationId\":\"{{orgId}}\",\"invoices\":[{\"invoiceNumber\":\"INV-001\",\"recipientEmail\":\"a@acme.co.zw\",\"totalAmount\":100,\"currency\":\"USD\"},{\"invoiceNumber\":\"INV-002\",\"recipientEmail\":\"b@acme.co.zw\",\"totalAmount\":200,\"currency\":\"USD\"}]}",
									"type": "text"
								},
								{
									"key": "INV-001",
									"type": "file",
									"src": "",
									"description": "PDF for INV-001"
								},
								{
									"key": "INV-002",
									"type": "file",
									"src": "",
									"description": "PDF for INV-002"
								}
							]
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/erp/dispatch/upload",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "erp", "dispatch", "upload"]
						},
						"description": "Upload multiple invoice PDFs and dispatch as a campaign.\n\nEach PDF's form field name must match the invoiceNumber in the metadata."
					},
					"response": []
				},
				{
					"name": "List Active ERP Adapters",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/erp/adapters",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "erp", "adapters"]
						},
						"description": "List all registered and active ERP adapters."
					},
					"response": []
				},
				{
					"name": "Check ERP Health",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{baseUrl}}/api/v1/erp/health/SAGE_INTACCT?tenantId=default",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "erp", "health", "SAGE_INTACCT"],
							"query": [
								{
									"key": "tenantId",
									"value": "default"
								}
							]
						},
						"description": "Check if an ERP adapter can reach its backend system."
					},
					"response": []
				}
			]
		},
