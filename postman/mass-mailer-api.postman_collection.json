					"name": "Create Rate Profile",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"name\": \"Standard\",\n  \"description\": \"Default tiered pricing for SMEs\",\n  \"currency\": \"USD\",\n  \"monthlyBaseFee\": 25.00,\n  \"tiers\": [\n    {\"tierName\": \"Base\", \"fromInvoice\": 1, \"toInvoice\": 500, \"ratePerInvoice\": 0.10},\n    {\"tierName\": \"Volume\", \"fromInvoice\": 501, \"toInvoice\": 2000, \"ratePerInvoice\": 0.07},\n    {\"tierName\": \"Enterprise\", \"fromInvoice\": 2001, \"toInvoice\": null, \"ratePerInvoice\": 0.04}\n  ]\n}"
						},
